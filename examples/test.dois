module MyModule has
  type Result is
    Err | Nil
  end

  type Err has
    message : Int
  end

  fn foo$() : Int =>
    5
  end

  fn add$(x : Int, y : Int) : Int =>
    x + y
  end

  proc print_sum(x : Int, y : Int) do
    let s = add$(x, y);
    print(s);
  end

  proc main() do
    let x : Int = 2;
    let y : Int = 10;
    print_sum(x, y);
  end
end

  